{
  "name": "onesixtwo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "fetch:lahman": "tsx scripts/fetch-lahman-data.ts",
    "build:data": "tsx scripts/build-player-data.ts",
    "build:active-data": "tsx scripts/build-active-player-data.ts",
    "validate:data": "tsx scripts/validate-player-data.ts",
    "analyze:ratings": "tsx scripts/analyze-rating-distributions.ts",
    "simulate:optimal": "tsx scripts/simulate-optimal-drafts.ts",
    "prebuild": "tsx scripts/prebuild-data.ts",
    "build": "tsc -b && vite build",
    "dev:pages": "npm run build && wrangler pages dev dist --compatibility-date=2024-01-01 --d1 DB=onesixtwo-leaderboard",
    "db:migrate:local": "wrangler d1 migrations apply onesixtwo-leaderboard --local",
    "db:migrate:remote": "wrangler d1 migrations apply onesixtwo-leaderboard --remote",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "npm run build && wrangler pages deploy dist --project-name onesixtwo"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@radix-ui/react-slot": "^1.2.4",
    "@resvg/resvg-wasm": "^2.6.2",
    "@tailwindcss/vite": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.16.0",
    "react-router-dom": "^7.16.0",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8",
    "wrangler": "^4.97.0"
  }
}
